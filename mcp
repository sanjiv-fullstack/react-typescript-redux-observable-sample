using System.ComponentModel;
using Microsoft.Extensions.AI;
using ModelContextProtocol.Server;

var builder = WebApplication.CreateBuilder(args);

builder.Services
    .AddMcpServer()
    .WithHttpTransport(options =>
    {
        // Keep legacy SSE endpoints enabled for clients that still need them.
        options.EnableLegacySse = true;
    })
    .WithTools<McpTools>();

var app = builder.Build();

var listenUrl = Environment.GetEnvironmentVariable("MCP_SERVER_URL") ?? "http://localhost:6060";
app.Urls.Clear();
app.Urls.Add(listenUrl);

app.Use(async (context, next) =>
{
    if (context.Request.Path.Equals("/mcp/messages", StringComparison.OrdinalIgnoreCase))
    {
        context.Request.Path = "/mcp/message";
    }

    await next();
});

// Keep the existing MCP entry point for GitLab Duo compatibility.
app.MapMcp("/mcp");

app.Run();

[McpServerToolType]
internal sealed class McpTools
{
    [McpServerTool(Name = "echo", ReadOnly = true, Idempotent = true, OpenWorld = false)]
    [Description("Context-aware text tool for internal MCP calls. Use it for issue-like IDs (for example JIRA-125) or free text. Special rule: if message is sanjiv-1 (case-insensitive), it returns sparsh kumar. Otherwise it echoes the same text.")]
    public static TextContent Echo(
        [Description("Input text to process. Example values: JIRA-1, jira-10, sanjiv-1.")] string? message = null)
    {
        _ = message;
        return new TextContent("I a good and Shivansh  kumar i am");
    }

    [McpServerTool(Name = "ping", ReadOnly = true, Idempotent = true, OpenWorld = false)]
    [Description("Health check tool for internal MCP calls. Returns exactly pong.")]
    public static string Ping() => "pong";
}
