using System.Collections.Concurrent;
using System.Text.Json;
using System.Text.Json.Nodes;
using System.Threading.Channels;

var builder = WebApplication.CreateBuilder(args);
builder.Services.AddSingleton<McpRequestHandler>();
builder.Services.AddSingleton<SseSessionStore>();
builder.Services.AddCors(options =>
{
    options.AddDefaultPolicy(policy =>
    {
        policy.AllowAnyOrigin().AllowAnyHeader().AllowAnyMethod();
    });
});

var app = builder.Build();
app.UseCors();
app.Use(async (context, next) =>
{
    Console.Error.WriteLine($"[{DateTime.UtcNow:O}] {context.Request.Method} {context.Request.Path}{context.Request.QueryString}");
    await next();
});

var mcpUrl = Environment.GetEnvironmentVariable("MCP_SERVER_URL") ?? "http://localhost:6060";
app.Urls.Clear();
app.Urls.Add(mcpUrl);

app.MapGet("/", () => Results.Ok(new
{
    service = "SimpleMcpServer",
    transport = "http+sse-compat",
    endpoint = "/mcp",
    sseEndpoint = "/sse",
    messagesEndpoint = "/mcp/messages?sessionId={sessionId}"
}));

app.MapGet("/health", () => Results.Ok(new
{
    status = "ok",
    nowUtc = DateTime.UtcNow
}));

app.MapGet("/sse", async (HttpContext context, SseSessionStore sessions) =>
{
    await HandleSseSessionAsync(context, sessions);
});

app.MapGet("/mcp/sse", async (HttpContext context, SseSessionStore sessions) =>
{
    await HandleSseSessionAsync(context, sessions);
});

app.MapGet("/mcp", async (HttpContext context, SseSessionStore sessions) =>
{
    await HandleSseSessionAsync(context, sessions);
});

app.MapPost("/mcp", async (HttpContext context, McpRequestHandler handler) =>
{
    var requestNode = await JsonNode.ParseAsync(context.Request.Body) as JsonObject;
    if (requestNode is null)
    {
        return Results.BadRequest(new { error = "Invalid JSON request body" });
    }

    var responseNode = await handler.HandleAsync(requestNode);
    if (responseNode is null)
    {
        return Results.Accepted();
    }

    if (context.Request.Headers.Accept.ToString().Contains("text/event-stream", StringComparison.OrdinalIgnoreCase))
    {
        context.Response.Headers.CacheControl = "no-cache";
        context.Response.ContentType = "text/event-stream";
        await WriteSseEventAsync(context, "message", responseNode.ToJsonString(McpRequestHandler.JsonOptions));
        return Results.Empty;
    }

    return Results.Json(responseNode, McpRequestHandler.JsonOptions);
});

app.MapPost("/messages", async (HttpContext context, SseSessionStore sessions, McpRequestHandler handler) =>
{
    var sessionId = context.Request.Query["sessionId"].ToString();
    if (string.IsNullOrWhiteSpace(sessionId))
    {
        return Results.BadRequest(new { error = "Missing sessionId query parameter" });
    }

    if (!sessions.TryGetWriter(sessionId, out var writer))
    {
        return Results.NotFound(new { error = "Unknown or expired session" });
    }

    var requestNode = await JsonNode.ParseAsync(context.Request.Body) as JsonObject;
    if (requestNode is null)
    {
        return Results.BadRequest(new { error = "Invalid JSON request body" });
    }

    var responseNode = await handler.HandleAsync(requestNode);
    if (responseNode is not null)
    {
        await writer.WriteAsync(responseNode.ToJsonString(McpRequestHandler.JsonOptions), context.RequestAborted);
    }

    return Results.Accepted();
});

app.MapPost("/mcp/messages", async (HttpContext context, SseSessionStore sessions, McpRequestHandler handler) =>
{
    var sessionId = context.Request.Query["sessionId"].ToString();
    if (string.IsNullOrWhiteSpace(sessionId))
    {
        return Results.BadRequest(new { error = "Missing sessionId query parameter" });
    }

    if (!sessions.TryGetWriter(sessionId, out var writer))
    {
        return Results.NotFound(new { error = "Unknown or expired session" });
    }

    var requestNode = await JsonNode.ParseAsync(context.Request.Body) as JsonObject;
    if (requestNode is null)
    {
        return Results.BadRequest(new { error = "Invalid JSON request body" });
    }

    var responseNode = await handler.HandleAsync(requestNode);
    if (responseNode is not null)
    {
        await writer.WriteAsync(responseNode.ToJsonString(McpRequestHandler.JsonOptions), context.RequestAborted);
    }

    return Results.Accepted();
});

app.Run();

static async Task HandleSseSessionAsync(HttpContext context, SseSessionStore sessions)
{
    context.Response.Headers.CacheControl = "no-cache";
    context.Response.Headers.Connection = "keep-alive";
    context.Response.ContentType = "text/event-stream";

    var session = sessions.CreateSession();
    var messageUrl = $"{context.Request.Scheme}://{context.Request.Host}/mcp/messages?sessionId={session.SessionId}";

    await WriteSseEventAsync(context, "endpoint", messageUrl);
    await WriteSseEventAsync(context, "ready", "{\"message\":\"sse connected\"}");

    try
    {
        while (!context.RequestAborted.IsCancellationRequested)
        {
            if (session.Reader.TryRead(out var pendingMessage))
            {
                await WriteSseEventAsync(context, "message", pendingMessage);
                continue;
            }

            var hasPendingTask = session.Reader.WaitToReadAsync(context.RequestAborted).AsTask();
            var pingDelayTask = Task.Delay(TimeSpan.FromSeconds(15), context.RequestAborted);
            var completed = await Task.WhenAny(hasPendingTask, pingDelayTask);
            if (completed == pingDelayTask)
            {
                await WriteSseEventAsync(context, "ping", $"{{\"utc\":\"{DateTime.UtcNow:O}\"}}");
            }
        }
    }
    catch (OperationCanceledException)
    {
    }
    finally
    {
        sessions.RemoveSession(session.SessionId);
    }
}

static async Task WriteSseEventAsync(HttpContext context, string eventName, string data)
{
    await context.Response.WriteAsync($"event: {eventName}\n");
    await context.Response.WriteAsync($"data: {data}\n\n");
    await context.Response.Body.FlushAsync();
}

internal sealed class SseSessionStore
{
    private readonly ConcurrentDictionary<string, Channel<string>> _sessions = new();

    public SseSession CreateSession()
    {
        var sessionId = Guid.NewGuid().ToString("N");
        var channel = Channel.CreateUnbounded<string>();
        _sessions[sessionId] = channel;
        return new SseSession(sessionId, channel.Reader);
    }

    public bool TryGetWriter(string sessionId, out ChannelWriter<string> writer)
    {
        writer = default!;
        if (!_sessions.TryGetValue(sessionId, out var channel))
        {
            return false;
        }

        writer = channel.Writer;
        return true;
    }

    public void RemoveSession(string sessionId)
    {
        _sessions.TryRemove(sessionId, out _);
    }
}

internal sealed record SseSession(string SessionId, ChannelReader<string> Reader);

internal sealed class McpRequestHandler
{
    public static readonly JsonSerializerOptions JsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = false
    };

    private readonly HttpClient _httpClient = new();
    private readonly string _apiBaseUrl;

    public McpRequestHandler()
    {
        _apiBaseUrl = Environment.GetEnvironmentVariable("SIMPLE_API_URL") ?? "http://localhost:5055";
    }

    public async Task<JsonObject?> HandleAsync(JsonObject message)
    {
        var method = message["method"]?.GetValue<string>();
        var idNode = message["id"];
        var isRequest = idNode is not null;

        if (string.IsNullOrWhiteSpace(method))
        {
            return isRequest ? BuildError(idNode, -32600, "Invalid Request: method is required") : null;
        }

        switch (method)
        {
            case "initialize":
                return isRequest ? BuildResult(idNode!, BuildInitializeResult()) : null;
            case "notifications/initialized":
            case "notifications/cancelled":
                return null;
            case "tools/list":
                return isRequest ? BuildResult(idNode!, BuildToolsListResult()) : null;
            case "tools/call":
                return isRequest ? BuildResult(idNode!, await ExecuteToolAsync(message["params"] as JsonObject)) : null;
            default:
                return isRequest ? BuildError(idNode, -32601, $"Method not found: {method}") : null;
        }
    }

    private static JsonObject BuildInitializeResult()
    {
        return new JsonObject
        {
            ["protocolVersion"] = "2024-11-05",
            ["capabilities"] = new JsonObject
            {
                ["tools"] = new JsonObject
                {
                    ["listChanged"] = false
                }
            },
            ["serverInfo"] = new JsonObject
            {
                ["name"] = "simple-mcp-server",
                ["version"] = "1.3.0"
            }
        };
    }

    private static JsonObject BuildToolsListResult()
    {
        return new JsonObject
        {
            ["tools"] = new JsonArray
            {
                new JsonObject
                {
                    ["name"] = "echo",
                    ["description"] = "Echoes the provided message.",
                    ["inputSchema"] = new JsonObject
                    {
                        ["type"] = "object",
                        ["properties"] = new JsonObject
                        {
                            ["message"] = new JsonObject
                            {
                                ["type"] = "string",
                                ["description"] = "Text to echo back."
                            }
                        }
                    }
                },
                new JsonObject
                {
                    ["name"] = "rest_hello",
                    ["description"] = "Calls the REST API /hello endpoint.",
                    ["inputSchema"] = new JsonObject
                    {
                        ["type"] = "object",
                        ["properties"] = new JsonObject
                        {
                            ["name"] = new JsonObject
                            {
                                ["type"] = "string",
                                ["description"] = "Optional name passed to /hello?name=."
                            }
                        }
                    }
                },
                new JsonObject
                {
                    ["name"] = "ping",
                    ["description"] = "Returns a pong response for transport and approval testing.",
                    ["inputSchema"] = new JsonObject
                    {
                        ["type"] = "object",
                        ["properties"] = new JsonObject()
                    }
                }
            }
        };
    }

    private async Task<JsonObject> ExecuteToolAsync(JsonObject? parameters)
    {
        var toolName = parameters?["name"]?.GetValue<string>();
        var arguments = parameters?["arguments"] as JsonObject;

        if (string.IsNullOrWhiteSpace(toolName))
        {
            return ErrorToolResult("Missing tool name.");
        }

        return toolName switch
        {
            "echo" => SuccessToolResult(arguments?["message"]?.GetValue<string>() ?? "(empty)"),
            "rest_hello" => await CallRestHelloToolAsync(arguments),
            "ping" => SuccessToolResult($"pong {DateTime.UtcNow:O}"),
            _ => ErrorToolResult($"Unknown tool: {toolName}")
        };
    }

    private async Task<JsonObject> CallRestHelloToolAsync(JsonObject? arguments)
    {
        var name = arguments?["name"]?.GetValue<string>();
        var endpoint = string.IsNullOrWhiteSpace(name) ? "/hello" : $"/hello?name={Uri.EscapeDataString(name)}";

        try
        {
            var response = await _httpClient.GetAsync($"{_apiBaseUrl.TrimEnd('/')}{endpoint}");
            var content = await response.Content.ReadAsStringAsync();

            return response.IsSuccessStatusCode
                ? SuccessToolResult(content)
                : ErrorToolResult($"REST call failed: {(int)response.StatusCode} {response.ReasonPhrase}. Body: {content}");
        }
        catch (Exception ex)
        {
            return ErrorToolResult($"REST call exception: {ex.Message}");
        }
    }

    private static JsonObject SuccessToolResult(string text)
    {
        return new JsonObject
        {
            ["content"] = new JsonArray
            {
                new JsonObject
                {
                    ["type"] = "text",
                    ["text"] = text
                }
            },
            ["isError"] = false
        };
    }

    private static JsonObject ErrorToolResult(string text)
    {
        return new JsonObject
        {
            ["content"] = new JsonArray
            {
                new JsonObject
                {
                    ["type"] = "text",
                    ["text"] = text
                }
            },
            ["isError"] = true
        };
    }

    private static JsonObject BuildResult(JsonNode id, JsonObject result)
    {
        return new JsonObject
        {
            ["jsonrpc"] = "2.0",
            ["id"] = id.DeepClone(),
            ["result"] = result
        };
    }

    private static JsonObject BuildError(JsonNode? id, int code, string message)
    {
        return new JsonObject
        {
            ["jsonrpc"] = "2.0",
            ["id"] = id?.DeepClone(),
            ["error"] = new JsonObject
            {
                ["code"] = code,
                ["message"] = message
            }
        };
    }
}
